{
  "manifest_version": 3,
  "name": "Link Inspector",
  "version": "1.1.25",
  "description": "Extract, review, copy, and export unique links from the current webpage.",
  "permissions": [
    "scripting",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "128": "images/icon128.png"
  }
}
